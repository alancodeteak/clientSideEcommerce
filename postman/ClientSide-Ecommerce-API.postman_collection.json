        {
          "name": "GET /api/oauth/dev/google-start",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/oauth/dev/google-start?shopId={{shopId}}",
            "description": "**302** to Google in a real browser. Query: optional **`shopId`**, **`callbackURL`**.\n\nRequires **`GOOGLE_CLIENT_ID`** / **`GOOGLE_CLIENT_SECRET`** / **`API_PUBLIC_URL`**."
          },
          "response": []
        },
        {
          "name": "GET /api/oauth/callback/google (browser only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/oauth/callback/google?code=PASTE_CODE&state=PASTE_STATE",
            "description": "Google redirects here with **`code`** and **`state`**. Not useful to run manually in Postman unless you paste real OAuth params immediately after redirect. On success sets **`storefront_oauth_exchange`** cookie."
          },
          "response": []
        },
        {
          "name": "POST /api/oauth/sign-in/social",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "{{corsOrigin}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"disableRedirect\": true,\n  \"callbackURL\": \"{{baseUrl}}/api/oauth/success\",\n  \"additionalData\": {\n    \"shopId\": \"{{shopId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/oauth/sign-in/social",
            "description": "**`disableRedirect: true`** â€” **200** `{ \"url\" }` for opening Google in browser.\n\nOmit **`disableRedirect`** for **302** redirect (browser + cookie state).\n\n**`additionalData.shopId`**: optional UUID to provision membership after Google.\n\n**503** if Google OAuth env missing."
          },
          "response": []
        }
      ]
