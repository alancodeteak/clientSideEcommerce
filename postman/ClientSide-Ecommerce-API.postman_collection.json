    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  if (j.shop && j.shop.id) pm.collectionVariables.set('shopId', j.shop.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopId\": \"{{shopId}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"Test Buyer\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "**201** â€” `accessToken`, `user`, `shop`, `customer`, `profile`. **409** â€” membership conflict.\n\nTest script saves **`accessToken`** and **`shopId`**.\n\n`password`: min 6 chars."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  if (j.shopIds && j.shopIds[0]) pm.collectionVariables.set('shopId', j.shopIds[0]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "**200** â€” `accessToken`, `shopIds`, `profile`. **401** â€” invalid credentials.\n\nTest script saves **`accessToken`** and first **`shopId`**."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/oauth/jwt (body {})",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  if (j.shopIds && j.shopIds[0]) pm.collectionVariables.set('shopId', j.shopIds[0]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/auth/oauth/jwt",
            "description": "**After Google callback:** Exchange **`storefront_oauth_exchange`** cookie for JWT. Body **`{}`** is valid (`email` optional in schema).\n\nRequires the cookie on the request (browser same-origin, or Postman cookie jar / manual cookie). **401** if cookie missing or invalid."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/oauth/jwt (dev email only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
                  "  if (j.shopIds && j.shopIds[0]) pm.collectionVariables.set('shopId', j.shopIds[0]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/oauth/jwt",
            "description": "**Dev only:** requires **`ALLOW_EMAIL_ONLY_JWT_EXCHANGE=true`** in `.env`. Mints JWT for an existing **user + customer** with this email. **403** if flag off and no cookie.\n\nClear bad **`storefront_oauth_exchange`** cookies in Postman if you get **401** with a valid email."
          },
          "response": []
        }
      ]
    },
