NODE_ENV=development
PORT=4100
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

JWT_SECRET=change_me_min_16_chars
JWT_ISSUER=clientside-ecommerce
JWT_AUDIENCE=clientside-ecommerce
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# Better Auth (Google OAuth) — HTTP routes under /api/oauth
# Full guide: ../docs/client-storefront-api.md (section "Google OAuth")
#
# 1) BETTER_AUTH_SECRET — NOT from Google. You generate it once:
#       cd clientSideEcommerce && npm run auth:secret
#    Copy the printed BETTER_AUTH_SECRET=... line into your real .env
#    (Or: openssl rand -base64 32 — must be 32+ characters.)
#
# 2) BETTER_AUTH_URL — Base URL of THIS API (no path). Must match how you open
#    the API in the browser (avoid mixing localhost vs 127.0.0.1).
#
# 3) GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET — from Google Cloud Console:
#    APIs & Services → Credentials → Create OAuth client (Web application).
#    Authorized redirect URI must be exactly:
#       {BETTER_AUTH_URL}{BETTER_AUTH_BASE_PATH}/callback/google
#    e.g. http://localhost:4100/api/oauth/callback/google
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=paste_output_of_npm_run_auth_secret_here_min_32_chars
BETTER_AUTH_URL=http://localhost:4100
BETTER_AUTH_BASE_PATH=/api/oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
