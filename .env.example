# Copy to `.env` and adjust. Application reads configuration from the environment only
# (no localhost / JWT / Google URL literals in business code). Vitest uses safe in-memory defaults when NODE_ENV=test.

NODE_ENV=development
PORT=4100

# Browser origin allowed for CORS (your storefront URL).
CORS_ORIGIN=http://localhost:5173

# Public base URL of this API (no trailing slash). OAuth redirect_uri = {API_PUBLIC_URL}/api/oauth/callback/google
API_PUBLIC_URL=http://localhost:4100

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Local Postgres without TLS: false. Production with verified TLS: true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Google Sign-In (leave ID/secret empty to disable social endpoints except /api/oauth/ok)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Official Google endpoints (override only if you use a proxy or Google changes URLs)
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
GOOGLE_OAUTH_SCOPE=openid email profile

# JWT for storefront sessions (min 16 characters; use a long random value in production)
JWT_SECRET=change_me_min_16_chars
JWT_ISSUER=clientside-ecommerce
JWT_AUDIENCE=clientside-ecommerce
JWT_EXPIRES_IN=8h

SERVICE_AREA_RADIUS_METERS=5000

# NEVER enable in production
ALLOW_EMAIL_ONLY_JWT_EXCHANGE=false
