{
  "name": "clientside-ecommerce-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main/bootstrap.js",
  "scripts": {
    "dev": "nodemon src/main/bootstrap.js",
    "start": "node src/main/bootstrap.js",
    "db:migrate": "node scripts/migrate.js",
    "db:prune": "node scripts/prune-noncanonical-tables.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "tunnel": "cloudflared tunnel --config cloudflared/config.yml run",
    "tunnel:login": "cloudflared tunnel login",
    "tunnel:bootstrap": "bash scripts/bootstrap-cloudflare-tunnel.sh"
  },
  "dependencies": {
    "@node-rs/bcrypt": "^1.10.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^4.3.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
