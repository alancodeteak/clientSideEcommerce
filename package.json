{
  "name": "clientside-ecommerce-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main/bootstrap.js",
  "scripts": {
    "dev": "nodemon src/main/bootstrap.js",
    "start": "node src/main/bootstrap.js",
    "db:migrate": "node scripts/migrate.js",
    "db:oauth:migrate": "npx auth@latest migrate --config ./src/infra/auth/betterAuth.js --yes",
    "auth:secret": "npx auth@latest secret",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@node-rs/bcrypt": "^1.10.7",
    "better-auth": "^1.5.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
